<div class="page-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px; margin-bottom: 20px;">
  
  <%# タイトルとバーコードを横並びにするコンテナ %>
  <div class="title-with-barcode" style="display: flex; align-items: center; gap: 15px;">
    <h1 style="margin: 0;">在庫詳細 (ID: <%= @inventory.id %>)</h1>
    
    <%# --- バーコードをタイトルの横に小さく表示 --- %>
    <% if defined?(barcode) %>
      <div class="small-barcode" style="background: #fff; padding: 2px 5px; border-radius: 4px; border: 1px solid #dddddd;">
        <%= image_tag barcode(@inventory), alt: "バーコード", style: "height: 50px; width: 150%; display: block;" %>
      </div>
    <% end %>
  </div>

<div class="header-actions" style="display: flex; gap: 10px; align-items: center;">
    <%# 削除ボタン (Turbo対応) %>
    <%= button_to inventory_path(@inventory), method: :delete, data: { turbo_confirm: "この在庫を削除してもよろしいですか？" }, class: "btn btn-danger", style: "margin: 0;" do %>
      <i class="fas fa-trash-alt"></i> 在庫を削除
    <% end %>
    <%# 戻るボタン %>
    <%= link_to inventories_path, class: "btn btn-secondary" do %>
      <i class="fas fa-arrow-left"></i> 在庫一覧へ戻る
    <% end %>
  </div>
</div>

<div class="detail-container">
  <%# --- 1. 部位の基本情報カード --- %>
  <div class="detail-card">
    <div class="card-header">
      <h2><i class="fas fa-cube"></i> 部位情報</h2>
      <%# ステータスによってラベルの色を変えると見やすいです %>
      <span class="status-badge status-<%= @inventory.status %>">
        <%= @inventory.status || "未設定" %>
      </span>
    </div>
    <div class="card-body">
      <table class="detail-table">
        <tbody>
          <tr>
            <th>部位名</th>
            <td><span class="highlight-text"><%= @inventory.part || "未登録" %></span></td>
          </tr>
          <tr>
            <th>重量</th>
            <td><%= @inventory.weight.present? ? "#{@inventory.weight} g" : "未登録" %></td>
          </tr>
          <tr>
            <th>賞味期限</th>
            <td>
              <i class="fas fa-calendar-times"></i> 
              <%= @inventory.expire_date ? @inventory.expire_date.strftime("%Y-%m-%d") : "未設定" %>
            </td>
          </tr>
          <tr>
            <th>登録日時</th>
            <td><%= @inventory.created_at.strftime("%Y-%m-%d %H:%M") %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <%# --- 2. 親の個体情報へのリンクカード --- %>
  <div class="detail-card">
    <div class="card-header">
      <h2><i class="fas fa-paw"></i> 紐づく個体情報</h2>
    </div>
    <div class="card-body">
      <% if @inventory.individual.present? %>
        <table class="detail-table">
          <tbody>
            <tr>
              <th>個体識別番号</th>
              <td><%= @inventory.individual.identification_id || "未登録" %></td>
            </tr>
            <tr>
              <th>種類</th>
              <td><%= @inventory.individual.species || "未登録" %></td>
            </tr>
            <tr>
              <th>捕獲地</th>
              <td><%= @inventory.individual.origin || "未登録" %></td>
            </tr>
            <tr>
              <th>加工日</th>
              <td><%= @inventory.individual.processing_date ? @inventory.individual.processing_date.strftime("%Y-%m-%d") : "未登録" %></td>
            </tr>
          </tbody>
        </table>
        <div class="card-actions" style="margin-top: 15px; text-align: right;">
          <%= link_to individual_path(@inventory.individual), class: "btn btn-outline" do %>
            <i class="fas fa-external-link-alt"></i> この個体の詳細を見る
          <% end %>
        </div>
      <% else %>
        <p>紐づく個体情報がありません。</p>
      <% end %>
    </div>
  </div>
</div>

<%# --- 簡単なCSS (必要に応じて application.css に移動してください) --- %>
<style>
  .detail-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 20px;
  }
  .detail-card {
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    overflow: hidden;
  }
  .detail-card .card-header {
    background: #f8f9fa;
    padding: 15px 20px;
    border-bottom: 1px solid #eee;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .detail-card .card-header h2 {
    margin: 0;
    font-size: 1.2em;
    color: #333;
  }
  .detail-card .card-body {
    padding: 20px;
  }
  .detail-table {
    width: 100%;
    border-collapse: collapse;
  }
  .detail-table th {
    text-align: left;
    padding: 10px 0;
    color: #666;
    width: 40%;
    border-bottom: 1px solid #f0f0f0;
  }
  .detail-table td {
    padding: 10px 0;
    border-bottom: 1px solid #f0f0f0;
    font-weight: 500;
  }
  .highlight-text {
    font-size: 1.2em;
    font-weight: bold;
    color: #2c3e50;
  }
  .btn-outline {
    display: inline-block;
    padding: 8px 15px;
    border: 1px solid #3498db;
    color: #3498db;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s;
  }
  .btn-outline:hover {
    background: #3498db;
    color: #fff;
  }
  .btn_danger {
    background: #e74c3c;
    color: #fff;
    border: none;
    padding: 8px 15px;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.3s;
  }
  /* スマホ表示対応 */
  @media (max-width: 768px) {
    .detail-container {
      grid-template-columns: 1fr;
    }
  }
</style>
