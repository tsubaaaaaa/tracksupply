<%# app/views/inventoriesiduals/index.html.erb %>

<%# 検索機能の実装 %>
<%# 検索フォームの作成 %>
<%= form_with url: inventories_path, method: :get, data: { turbo_frame: "_top" } do |f| %>
  <%# data: { turbo_frame: "_top" } は、もしTurboを使っていて、検索結果でページ全体を更新したい場合に有効 %>
  <div class="search-form">
    <%= f.text_field :keyword, value: params[:keyword], placeholder: "キーワードを入力", class: "search-input" %>
    <%# または、モデルに紐づけないなら text_field_tag のままでもOK %>
    <%# <%= text_field_tag :keyword, params[:keyword], placeholder: "キーワードを入力", class: "search-input" %> 
    <%= f.submit "検索", class: "search-button" %>
  </div>
<% end %>

<div class="inventories-container">

<div class="inventories-card legend-card" style="background-color: #f8f9fa; border: 2px dashed #ccc; margin-bottom: 20px;">
  <div class="inventories-card-wrapper">
    <p class="inventories-card-id"><i class="fas fa-hashtag"></i> 出荷ID</p>
    <p class="inventories-card-line"><i class="fas fa-utensils"></i> 部位名</p>
    <p class="inventories-card-line"><i class="fas fa-weight-scale"></i> 重量</p>
    <p class="inventories-card-line"><i class="fas fa-store"></i> 出荷先</p>
    <p class="inventories-card-line"><i class="fas fa-calendar-alt"></i> 出荷日</p>     
  </div>
</div>

<%# inventoriesのうち current_user が作成したものを表示 %>
  <% @inventories.each do |i| %>
    <%# カード全体をリンクにする代わりに、Railsの link_to ヘルパーを使う方法もあります %>
    <%# 例: <%= link_to inventoriesidual_path(i.id), class: "card clickable-card" do %>
    <div class="inventories-card clickable-card" onclick="location.href='<%= shipment_path(i.shipments.last) %>'">
      <div class="inventories-card-wrapper">
          <p class="inventories-card-id">
            <i class="fas fa-hashtag"></i>
            <% if i.respond_to?(:shipments) && i.shipments.any? %>
              <%= i.shipments.last.id %>
            <% else %>
            <% end %>
          </p>
          <p class="inventories-card-line">
            <i class="fas fa-utensils"></i>
            <%= i.part ? i.part  : "未登録" %> <%# 不正な </span> を削除 %>
          </p>
          <p class="inventories-card-line">
            <i class="fas fa-weight-scale"></i>
            <%= i.weight.present? ? "#{i.weight.round(0)} g" : "未登録" %> <%# 不正な </span> を削除 %>
          </p>
            <p class="inventories-card-line">
            <i class="fas fa-store"></i> 
            <% if i.respond_to?(:shipments) && i.shipments.any? && i.shipments.last.customer %>
              <%= i.shipments.last.customer %>
            <% else %>
              未登録
            <% end %>
          </p>
            <p class="inventories-card-line">
            <i class="fas fa-calendar-alt"></i>
            <% if i.respond_to?(:shipments) && i.shipments.any? && i.shipments.last.ship_date %>
              <%= i.shipments.last.ship_date %>
            <% else %>
              未登録
            <% end %>
          </p>
      </div> <%# class="inventories-card-wrapper" %>    
    </div> <%# class="inventories-card clickable-card" %>
  <% end %>
</div>
